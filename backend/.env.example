PORT=5001
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0
CLIENT_ORIGIN=https://your-frontend.vercel.app
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES=7d
SEED_KEY=replace_with_a_seed_key

# ── Mailjet ──────────────────────────────────────────────────────────────────
# Get these from https://app.mailjet.com/account/apikeys
MAILJET_API_KEY=your_mailjet_api_key
MAILJET_SECRET_KEY=your_mailjet_secret_key
MAIL_FROM_EMAIL=noreply@yourdomain.com
MAIL_FROM_NAME=Daystar Service Planner
